# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/easyapproval

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Firebase Storage (file uploads)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Resend (email)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Easy Approval <onboarding@resend.dev>
CONTACT_EMAIL=admin@easyapproval.com
# Customers send documents to this email after payment
DOCUMENTS_EMAIL=aideveloperindia@gmail.com

# JWT (admin auth)
JWT_SECRET=your-random-secret-min-32-chars

# NextAuth (Google sign-in)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# App URL (for invoice links, API calls)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Legal / policy pages (payment gateway compliance — Razorpay, Cashfree, etc.)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=India Easy Approvals LLP
NEXT_PUBLIC_REGISTERED_OFFICE=Full address, City, State, PIN, India
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
NEXT_PUBLIC_SUPPORT_PHONE=+91-00000-00000
# Optional: show on Terms page
NEXT_PUBLIC_GSTIN=

# GitHub (optional - for git push after phases)
# GITHUB_TOKEN=ghp_xxxx
